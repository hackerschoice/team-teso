${ac_dA}DISABLE_UTMPX${ac_dB}DISABLE_UTMPX${ac_dC}1${ac_dD}
${ac_uA}DISABLE_UTMPX${ac_uB}DISABLE_UTMPX${ac_uC}1${ac_uD}
