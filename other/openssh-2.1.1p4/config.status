  esac

  echo creating $ac_file

  rm -f conftest.frag conftest.in conftest.out
  ac_file_inputs=`echo $ac_file_in|sed -e "s%^%$ac_given_srcdir/%" -e "s%:% $ac_given_srcdir/%g"`
  cat $ac_file_inputs > conftest.in

  cat > conftest.frag <<CEOF
${ac_dA}DONT_TRY_OTHER_AF${ac_dB}DONT_TRY_OTHER_AF${ac_dC}1${ac_dD}
${ac_uA}DONT_TRY_OTHER_AF${ac_uB}DONT_TRY_OTHER_AF${ac_uC}1${ac_uD}
${ac_eA}DONT_TRY_OTHER_AF${ac_eB}DONT_TRY_OTHER_AF${ac_eC}1${ac_eD}
${ac_dA}PAM_TTY_KLUDGE${ac_dB}PAM_TTY_KLUDGE${ac_dC}1${ac_dD}
${ac_uA}PAM_TTY_KLUDGE${ac_uB}PAM_TTY_KLUDGE${ac_uC}1${ac_uD}
${ac_eA}PAM_TTY_KLUDGE${ac_eB}PAM_TTY_KLUDGE${ac_eC}1${ac_eD}
${ac_dA}HAVE_LIBZ${ac_dB}HAVE_LIBZ${ac_dC}1${ac_dD}
