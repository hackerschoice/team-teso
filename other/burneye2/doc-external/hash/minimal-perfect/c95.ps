save

/dic 12 dict def

/RES
{
   dic begin
   /cn exch def
   /new exch def
   /bf exch def

   /bd bf findfont def
   /fo bd maxlength dict def

   bd
   {
     exch dup /FID ne
     {
       dup /Encoding eq
       {
     exch dup length array copy
     fo 3 1 roll put
       }
       {
     exch fo 3 1 roll put
       }
       ifelse
     }
     {
       pop pop
     }
     ifelse
   }
   forall

   fo /FontName new put
   cn aload pop

   cn length 2 idiv
   {
     fo /Encoding get 3 1 roll put
   }
   repeat

   new fo definefont pop
   end
} def

/pcVector [
